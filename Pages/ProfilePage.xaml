<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DeliveryApp.ProfilePage"
             Title="Profile"
             BackgroundColor="#FAFAFA">

    <NavigationPage.TitleView>
        <Grid Margin="0,0,10,0">
            <Label Text="Profile" FontSize="20" TextColor="White" VerticalOptions="Center"/>
        </Grid>
    </NavigationPage.TitleView>

    <VerticalStackLayout Margin="30" Spacing="20">
        <Label Text="Courier: Xiao Ming" 
               FontSize="32" 
               FontAttributes="Bold" 
               TextColor="#0052CC"
               HorizontalOptions="Center"
               Margin="0,40,0,20"/>

        <Button Text="My Orders"
                BackgroundColor="#0078D4"
                TextColor="White"
                FontSize="18"
                CornerRadius="20"
                HeightRequest="50"
                Clicked="OnMyOrdersClicked"/>

        <Button Text="Log Out"
                BackgroundColor="#F5222D"
                TextColor="White"
                FontSize="18"
                CornerRadius="20"
                HeightRequest="50"
                Clicked="OnLogOutClicked"/>
    </VerticalStackLayout>

</ContentPage>