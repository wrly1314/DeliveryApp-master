<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryLight">#3B82F6</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="Secondary">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Neutral">#64748B</Color>
    <Color x:Key="Background">#F8FAFC</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>

    <Color x:Key="StatusPending">#64748B</Color>
    <Color x:Key="StatusInTransit">#2563EB</Color>
    <Color x:Key="StatusCompleted">#10B981</Color>

    <Style x:Key="TitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource PrimaryDark}"/>
    </Style>

    <Style x:Key="SubtitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource Neutral}"/>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="CardStyle" TargetType="VerticalStackLayout">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00000020" Offset="0,4" Radius="8" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InfoBadgeStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextColor" Value="{StaticResource Primary}"/>
        <Setter Property="BackgroundColor" Value="#EFF6FF"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

</ResourceDictionary>